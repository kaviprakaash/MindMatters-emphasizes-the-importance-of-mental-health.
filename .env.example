# Copy this file to `.env` and fill in values. Never commit `.env`.

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret

# Must match an "Authorized redirect URI" in that OAuth client, without the path:
#   {PUBLIC_BASE_URL}/login/google/callback
# Leave unset for local dev if you open the app at http://127.0.0.1:5000
# PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# Flask session signing (change in production)
# SECRET_KEY=use-a-long-random-string
